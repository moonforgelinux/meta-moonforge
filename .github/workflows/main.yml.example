name: main
on:
  push:
    branches:
      - main
    paths-ignore:
      - '**.md'
  pull_request:
    branches:
      - main
    paths-ignore:
      - '**.md'
jobs:
  build:
    if: github.event.repository.fork == false
    runs-on: self-hosted
    strategy:
      matrix:
        machine:
          - qemux86-64
          - raspberrypi5
    steps:
      - uses: actions/checkout@v6
      - uses: rlespinasse/github-slug-action@v5
      - uses: moonforgelinux/build-moonforge-action@v0.1.0
        with:
          kas_file: kas/examples/moonforge-image-base-${{ matrix.machine }}.yml:kas/common/debug.yml
          dl_dir: ${{ vars.DL_DIR }}
          sstate_dir: ${{ vars.SSTATE_DIR }}
          image_id: ${{ env.GITHUB_REF_NAME_SLUG }}
          image_version: ${{ github.run_id }}
      - uses: moonforgelinux/upload-moonforge-action@v0.1.0
        if: >
           github.event_name == 'push' || (
           github.event_name == 'pull_request' &&
           github.event.pull_request.head.repo.fork == false )
        with:
          host_base: ${{ secrets.S3_HOST_BASE }}
          access_key: ${{ secrets.S3_ACCESS_KEY }}
          secret_key: ${{ secrets.S3_SECRET_KEY }}
          bucket: ${{ secrets.S3_BUCKET }}
          source: build/tmp/deploy/images/${{ matrix.machine }}
          destination: meta-moonforge/${{ github.ref }}/${{ github.run_id }}/
          exclude: '*'
          include: '*.wic.*'

  publish:
    if: >
      github.event_name == 'pull_request' &&
      github.event.pull_request.head.repo.fork == false
    runs-on: self-hosted
    needs: build
    permissions:
      pull-requests: write
    steps:
      - uses: mshick/add-pr-comment@v2
        with:
          message-id: ${{ github.run_id }}
          message-success: |
            Successfully built [${{ github.run_id }}](${{ vars.S3_PUBLIC_URL }}/meta-moonforge/${{ github.ref }}/${{ github.run_id }}/) :rocket:
