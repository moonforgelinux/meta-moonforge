From 318fcd6194e94379bc5de2d8aefaa5d3f40244de Mon Sep 17 00:00:00 2001
From: Martin Abente Lahaye <mabente@igalia.com>
Date: Wed, 6 May 2026 11:15:37 -0300
Subject: [PATCH] volatile-binds: Resolve many service ordering issues

---
 .../volatile-binds/files/volatile-binds.service.in             | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/meta/recipes-core/volatile-binds/files/volatile-binds.service.in b/meta/recipes-core/volatile-binds/files/volatile-binds.service.in
index 5a0055bec3..3da74abb5d 100644
--- a/meta/recipes-core/volatile-binds/files/volatile-binds.service.in
+++ b/meta/recipes-core/volatile-binds/files/volatile-binds.service.in
@@ -2,6 +2,9 @@
 Description=Bind mount volatile @where@
 DefaultDependencies=no
 Before=local-fs.target
+After=systemd-remount-fs.service
+Before=systemd-networkd-persistent-storage.service systemd-timesyncd.service
+Requires=systemd-remount-fs.service
 RequiresMountsFor=@whatparent@ @whereparent@
 ConditionPathIsReadWrite=|@whatparent@
 ConditionPathExists=|!@whatparent@
-- 
2.54.0

